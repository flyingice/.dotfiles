macos-option-as-alt = true

theme = Atom One Dark

font-family = JetBrainsMono Nerd Font Mono
font-size = 14

keybind = ctrl+a>p=toggle_command_palette

# Prompt navigation
keybind = ctrl+a>left_bracket=jump_to_prompt:-1
keybind = ctrl+a>right_bracket=jump_to_prompt:1

# --- tmux-style keybindings (prefix: ctrl+a) ---
# Mapping: tmux sessions → ghostty windows, tmux windows → ghostty tabs, tmux panes → ghostty splits

# Window management (tmux "session" equivalents)
keybind = ctrl+a>ctrl+c=new_window

# Tab management (tmux "window" equivalents)
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>shift+seven=close_tab
keybind = ctrl+a>,=prompt_tab_title
keybind = ctrl+a>ctrl+h=previous_tab
keybind = ctrl+a>ctrl+l=next_tab
keybind = ctrl+a>tab=last_tab
keybind = ctrl+a>zero=goto_tab:1
keybind = ctrl+a>one=goto_tab:2
keybind = ctrl+a>two=goto_tab:3
keybind = ctrl+a>three=goto_tab:4
keybind = ctrl+a>four=goto_tab:5
keybind = ctrl+a>five=goto_tab:6
keybind = ctrl+a>six=goto_tab:7
keybind = ctrl+a>seven=goto_tab:8
keybind = ctrl+a>eight=goto_tab:9
keybind = ctrl+a>nine=goto_tab:10

# Split management (tmux "pane" equivalents)
keybind = ctrl+a>shift+backslash=new_split:right
keybind = ctrl+a>shift+minus=new_split:down
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>ctrl+a=goto_split:next
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>shift+equal=toggle_split_zoom
